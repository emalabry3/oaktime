\000a-- Phase 1.2 : Design (EN_COURS — partiellement terminé)\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (6, 'Design UX/UI',\000d\000a        'Conception des maquettes, système de design et prototypes interactifs.',\000d\000a        DATEADD('DAY', -60, NOW()), '2025-03-03', '2025-05-30', NULL, 'EN_COURS', 1);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (7, 'Charte graphique',\000d\000a        'Définition de la palette de couleurs, typographies, iconographie et composants de base.',\000d\000a        DATEADD('DAY', -59, NOW()), '2025-03-03', '2025-03-28', NULL, 'TERMINE', 6);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (8, 'Maquettes pages principales',\000d\000a        'Home, page produit, contact, blog [*]— responsive mobile-first.',\000d\000a        DATEADD('DAY', -58, NOW()), '2025-03-31', '2025-04-30', '2025-05-15', 'EN_COURS', 6);\000d\000a-- Cas : date corrigée > date initiale → RETARD, fin dépassée\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (9, 'Prototype interactif Figma',\000d\000a        'Assemblage des maquettes en prototype cliquable pour tests utilisateurs.',\000d\000a        DATEADD('DAY', -57, NOW()), '2025-05-19', '2025-05-30', NULL, 'BACKLOG', 6);\000d\000a-- Cas : bloquée par 8 (prédécesseur EN_COURS)\000d\000a\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (8, 7);\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (9, 8);\000d\000a\000d\000a-- Phase 1.3 : Développement (BACKLOG — pas encore démarré)\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (10, 'Développement',\000d\000a        'Intégration front-end, développement CMS, API et mise en production.',\000d\000a        DATEADD('DAY', -30, NOW()), '2025-06-02', '2025-09-26', NULL, 'BACKLOG', 1);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (11, 'Intégration HTML/CSS',\000d\000a        'Intégration pixel-perfect des maquettes validées. Accessibilité WCAG AA.',\000d\000a        DATEADD('DAY', -29, NOW()), '2025-06-02', '2025-07-11', NULL, 'BACKLOG', 10);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (12, 'Configuration CMS',\000d\000a        'Paramétrage WordPress/Strapi, création des types de contenus, rôles et permissions.',\000d\000a        DATEADD('DAY', -29, NOW()), '2025-07-14', '2025-08-08', NULL, 'BACKLOG', 10);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (13, 'Tests et recette',\000d\000a        'Tests fonctionnels, tests de charge, correction des anomalies et livraison.',\000d\000a        DATEADD('DAY', -28, NOW()), '2025-08-11', '2025-09-19', '2025-09-26', 'BACKLOG', 10);\000d\000a\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (12, 11);\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (13, 12);\000d\000a\000d\000a\000d\000a-- =============================================================================\000d\000a-- PROJET 2 : ""Migration infrastructure cloud""\000d\000a-- Cas couverts :\000d\000a--   - Tâche racine sans sous-tâches (feuille racine)\000d\000a--   - Propagation auto TERMINE ascendante\000d\000a--   - Tâches dont la date de fin initiale est dans le futur (pas de dépassement)\000d\000a--   - Tâche avec uniquement date de fin initiale (pas de corrigée)\000d\000a--   - Plusieurs prédécesseurs sur une même tâche\000d\000a-- =============================================================================\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (20, 'Migration infrastructure cloud',\000d\000a        'Migration des serveurs on-premise vers AWS. Objectif : haute disponibilité, réduction des coûts de 30%.',\000d\000a        DATEADD('DAY', -45, NOW()), DATEADD('DAY', 5, CURRENT_DATE), DATEADD('DAY', 120, CURRENT_DATE), NULL, 'BACKLOG', NULL);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (21, 'Inventaire des services',\000d\000a        'Cartographie complète des applications, bases de données et dépendances à migrer.',\000d\000a        DATEADD('DAY', -44, NOW()), DATEADD('DAY', 5, CURRENT_DATE), DATEADD('DAY', 20, CURRENT_DATE), NULL, 'BACKLOG', 20);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (22, 'Architecture cible AWS',\000d\000a        'Conception de l''architecture VPC, subnets, sécurité, load balancer et auto-scaling.',\000d\000a        DATEADD('DAY', -44, NOW()), DATEADD('DAY', 21, CURRENT_DATE), DATEADD('DAY', 40, CURRENT_DATE), NULL, 'BACKLOG', 20);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (23, 'Migration base de données',\000d\000a        'Dump, transformation et import des bases PostgreSQL et MongoDB avec validation des données.',\000d\000a        DATEADD('DAY', -43, NOW()), DATEADD('DAY', 41, CURRENT_DATE), DATEADD('DAY', 70, CURRENT_DATE), NULL, 'BACKLOG', 20);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (24, 'Migration applicative',\000d\000a        'Déploiement des containers Docker sur ECS Fargate, configuration CI/CD.',\000d\000a        DATEADD('DAY', -43, NOW()), DATEADD('DAY', 71, CURRENT_DATE), DATEADD('DAY', 100, CURRENT_DATE), NULL, 'BACKLOG', 20);\000d\000a\000d\000aINSERT INTO tache (id, nom, description, date_creation, date_debut, date_fin_initiale, date_fin_corrigee, statut_kanban, parent_id)\000d\000aVALUES (25, 'Tests de bascule et go-live',\000d\000a        'Simulation de bascule, tests de charge, validation client et mise en production.',\000d\000a        DATEADD('DAY', -42, NOW()), DATEADD('DAY', 101, CURRENT_DATE), DATEADD('DAY', 120, CURRENT_DATE), NULL, 'BACKLOG', 20);\000d\000a\000d\000a-- Chaîne de prédécesseurs : 22→21, 23→22, 24→23, 25→21+23+24 (3 prédécesseurs)\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (22, 21);\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (23, 22);\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (24, 23);\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (25, 21);\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (25, 23);\000d\000aINSERT INTO tache_predecesseur (tache_id, predecesseur_id) VALUES (25, 24);\000d\000a\000d\000a\000d\000a-- =============================================================================\000d\000a-- PROJET 3 : ""Formation équipe dev""\000d\000a-- Cas couverts :\000d\000a--   - Toutes sous-tâches TERMINE → parent auto-terminé\000d\000a--   - Tâche sans description (champ optionnel)\000d\000a--   - Tâche sans date de début (pas encore planifiée)\000d\000a--   - Tâche feuille racine (sans enfants ni